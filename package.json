{
  "name": "company-mcp-server",
  "version": "0.3.16",
  "description": "MCP server for the local company orchestration API. Fills gaps in the paperclipai CLI for Claude Code sessions.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "company-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khgs2411/company-mcp-server.git"
  },
  "homepage": "https://github.com/khgs2411/company-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/khgs2411/company-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "company",
    "ai",
    "agent",
    "claude",
    "model-context-protocol"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --banner '#!/usr/bin/env bun'",
    "dev": "bun run src/index.ts",
    "test": "bun test tests/client.test.ts tests/shared tests/tools",
    "test:integration": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun test tests/client.test.ts tests/shared tests/tools && bun run build",
    "release": "./scripts/release.sh",
    "release:dry-run": "./scripts/release.sh --dry-run",
    "release:test": "./scripts/release.sh --test-publish",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@paperclipai/shared": "2026.513.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
